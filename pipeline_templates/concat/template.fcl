#include "Production/JobConfig/pileup/MuonStopSelector.fcl"

# MuonStopSelector reads source.fileNames (filled by mu2ejobdef --inputs)
# and writes mu-/mu+ TargetStops into separate art files. No G4, no geometry
# dependency, so the BO geom overlay is NOT shipped with this stage.

outputs.muminusout.fileName: "sim.owner.MuminusStopsCat.version.sequencer.art"
outputs.muplusout.fileName:  "sim.owner.MuplusStopsCat.version.sequencer.art"
